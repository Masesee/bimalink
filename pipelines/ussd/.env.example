# Scoring backend microservice endpoint
SCORING_SERVICE_URL=http://localhost:8000/score

# Note: No API keys are required for this local USSD gateway callback layer.
# In the Africa's Talking sandbox (https://account.africastalking.com/):
# 1. Start ngrok tunnel locally on port 5000: `ngrok http 5000`
# 2. Register the callback URL under your Sandbox USSD channel: `https://<ngrok-subdomain>.ngrok-free.app/ussd`
